---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  active?: "home" | "youtube" | "caster" | "updates";
}

const { title, description = "", active } = Astro.props;
const base = import.meta.env.BASE_URL;

const nav = [
  { key: "home", label: "アーカイブ", href: base },
  { key: "youtube", label: "公式YouTube", href: `${base}youtube/video` },
  { key: "caster", label: "キャスター", href: `${base}caster/` },
  { key: "updates", label: "更新情報", href: `${base}updates` },
];
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
	</head>
	<body class="min-h-screen bg-neutral-50 text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100">
		<header class="sticky top-0 z-30 border-b border-neutral-200/70 bg-neutral-50/80 backdrop-blur-md dark:border-neutral-800/70 dark:bg-neutral-950/80">
			<div class="mx-auto flex max-w-5xl flex-col gap-2 px-4 py-2.5 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
				<a href={base} class="flex shrink-0 items-center gap-2 font-semibold tracking-tight">
					<span class="flex h-6 w-6 items-center justify-center rounded-md bg-sky-600 text-xs text-white dark:bg-sky-500">WN</span>
					<span>LiVE アーカイブ</span>
				</a>
				<nav class="-mx-1 flex items-center gap-0.5 overflow-x-auto text-sm sm:mx-0 sm:gap-1">
					{nav.map((n) => (
						<a
							href={n.href}
							aria-current={active === n.key ? "page" : undefined}
							class={`shrink-0 rounded-lg px-3 py-1.5 transition-colors ${
								active === n.key
									? "bg-sky-100 font-medium text-sky-800 dark:bg-sky-950 dark:text-sky-300"
									: "text-neutral-600 hover:bg-neutral-200/60 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800/60 dark:hover:text-neutral-100"
							}`}
						>
							{n.label}
						</a>
					))}
				</nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="mx-auto max-w-5xl px-4 pb-10 pt-4">
			<div class="border-t border-neutral-200 pt-6 dark:border-neutral-800">
				<nav class="mb-3 flex flex-wrap gap-x-4 gap-y-1 text-sm">
					{nav.map((n) => (
						<a href={n.href} class="text-neutral-500 hover:text-sky-700 hover:underline dark:hover:text-sky-400">{n.label}</a>
					))}
				</nav>
				<p class="text-xs text-neutral-400">
					非公式のファンサイトです。出典: ウェザーニュース公式 / YouTube
				</p>
			</div>
		</footer>
	</body>
</html>
