---
import Layout from "../../layouts/Layout.astro";
import CasterDetail from "../../components/CasterDetail.tsx";
import meta from "../../data/meta.json";
import profiles from "../../data/caster-profiles.json";

export function getStaticPaths() {
  return meta.casters.map((c: { name: string; slug: string }) => ({
    params: { slug: c.slug },
    props: { name: c.name },
  }));
}

const { name } = Astro.props;
const profile = (profiles as Record<string, any>)[name.replace(/\s/g, "")] ?? {};
