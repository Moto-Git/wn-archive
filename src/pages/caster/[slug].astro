		<meta name="description" content={`${name}гБМжЛЕељУгБЧгБЯгВ¶гВІгВґгГЉгГЛгГ•гГЉгВєLiVEгБЃжФЊйАБдЄАи¶ІгБ®зµ±и®И`} />
	</head>
	<body class="bg-neutral-50 dark:bg-neutral-950">
