---
import "../../styles/global.css";
import CasterDetail from "../../components/CasterDetail.tsx";
import meta from "../../data/meta.json";
import sns from "../../data/caster-sns.json";

export function getStaticPaths() {
  return meta.casters.map((c: { name: string; slug: string }) => ({
    params: { slug: c.slug },
    props: { name: c.name },
  }));
}

const { name } = Astro.props;
const casterSns = (sns as Record<string, { x?: string; instagram?: string; youtube?: string }>)[name] ?? {};
