---
import Layout from "../../layouts/Layout.astro";
import YtList from "../../components/YtList.tsx";

const LABEL: Record<string, string> = { video: "動画", short: "ショート", live: "ライブ" };

export function getStaticPaths() {
  return ["video", "short", "live"].map((type) => ({ params: { type } }));
}

const { type } = Astro.params as { type: "video" | "short" | "live" };
---

<Layout
	title={`公式YouTube・${LABEL[type]} | ウェザーニュースLiVE アーカイブ`}
	description={`ウェザーニュース公式YouTubeの${LABEL[type]}一覧。並び替え・年別・タイトル検索に対応。`}
	active="youtube"
>
	<YtList type={type} client:idle />
</Layout>
